PORT=3000
NODE_ENV=development
CLIENT_ORIGIN=
CORS_ORIGIN=

MYSQL_HOST=your-aiven-mysql-host
MYSQL_PORT=your-aiven-mysql-port
MYSQL_USER=your-aiven-mysql-user
MYSQL_PASSWORD=replace-with-your-aiven-password
MYSQL_DATABASE=your-aiven-mysql-database
MYSQL_SSL=true
MYSQL_SSL_REJECT_UNAUTHORIZED=false
# Optional, recommended for strict certificate verification:
# MYSQL_SSL_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

JWT_SECRET=replace-with-a-long-random-secret
ADMIN_USERNAME=Claude
ADMIN_PASSWORD=replace-with-a-strong-password
